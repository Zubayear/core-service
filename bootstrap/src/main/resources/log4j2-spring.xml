<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="30">

    <Properties>
        <Property name="LOG_PATTERN">
            %d{yyyy-MM-dd HH:mm:ss.SSS} [%t] [%X{correlationId}] [%X{userId}] [%X{tenantId}] %-5level %logger{36} - %msg%n
        </Property>
        <Property name="APP_LOG_DIR">${sys:LOG_DIR:-logs}</Property>
        <Property name="APP_NAME">core-service</Property>
    </Properties>

    <Appenders>
        <!-- Console -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}" />
        </Console>

        <!-- Rolling File -->
        <RollingFile name="File"
                     fileName="${APP_LOG_DIR}/${APP_NAME}.log"
                     filePattern="${APP_LOG_DIR}/${APP_NAME}-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}" />
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" />
                <SizeBasedTriggeringPolicy size="50MB" />
            </Policies>
            <DefaultRolloverStrategy max="30" />
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Application loggers -->
        <Logger name="com.lucienvirecourt.coreservice.model"
                level="DEBUG" additivity="false">
            <AppenderRef ref="Console" />
            <AppenderRef ref="File" />
        </Logger>

        <Logger name="com.lucienvirecourt.coreservice.application"
                level="DEBUG" additivity="false">
            <AppenderRef ref="Console" />
            <AppenderRef ref="File" />
        </Logger>

        <Logger name="com.lucienvirecourt.coreservice.adapter"
                level="DEBUG" additivity="false">
            <AppenderRef ref="Console" />
            <AppenderRef ref="File" />
        </Logger>

        <!-- Spring / Hibernate noise -->
        <Logger name="org.springframework" level="INFO" />
        <Logger name="org.hibernate" level="WARN" />
        <Logger name="org.apache" level="WARN" />

        <Root level="INFO">
            <AppenderRef ref="Console" />
            <AppenderRef ref="File" />
        </Root>
    </Loggers>
</Configuration>